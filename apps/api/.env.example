# Database
DATABASE_URL="postgresql://user:password@host:5432/eqb_platform"

# Server
API_PORT=3001
NODE_ENV=development

# Authentication
JWT_SECRET="your-secret-key-minimum-32-characters-long"
ENCRYPTION_KEY="32-character-encryption-key-change-in-production"

# CORS - Comma-separated list of allowed origins
WEB_ALLOWED_ORIGINS="http://localhost:3000,https://eqb-coworker-platform.vercel.app"

# Redis (for Bull queues)
REDIS_URL="redis://default:password@host:6379"

# Email (SendGrid)
SENDGRID_API_KEY="SG.your_sendgrid_api_key_here"
FROM_EMAIL="noreply@eqbmilano.it"
FROM_NAME="EQB Platform"

# Google Calendar API
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"
GOOGLE_REDIRECT_URI="http://localhost:3001/api/auth/google/callback"
GOOGLE_ORG_CALENDAR_ID="your-org-calendar-id@group.calendar.google.com"

# Logging
LOG_LEVEL="info"
SENDGRID_API_KEY="SG.your-sendgrid-api-key"
FROM_EMAIL="noreply@eqbplatform.com"
FROM_NAME="EQB Platform"

# AWS S3 (for document storage)
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="eu-south-1"
AWS_S3_BUCKET_NAME="eqb-platform-documents"

# Application
WEB_BASE_URL="https://your-vercel-app.vercel.app"
NODE_ENV="production"
PORT=3001

# Logging
LOG_LEVEL="info"
