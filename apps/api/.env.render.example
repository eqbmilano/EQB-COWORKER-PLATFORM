# Render Environment Variables for API
# Copy these to Render Dashboard → Settings → Environment Variables

# Database
DATABASE_URL=postgresql://eqb_user:PASSWORD@HOST:5432/eqb_platform

# Server
NODE_ENV=production
API_PORT=3000

# JWT
JWT_SECRET=your-super-secret-jwt-key-here

# Email (optional)
SENDGRID_API_KEY=your-sendgrid-key

# AWS S3 (optional)
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_S3_BUCKET=your-bucket-name
AWS_REGION=eu-west-1

# Web App URL (for CORS)
WEB_ALLOWED_ORIGINS=*.vercel.app,https://eqb-coworker-platform-api.vercel.app
