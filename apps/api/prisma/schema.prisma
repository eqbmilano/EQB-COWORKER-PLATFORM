generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String     @id @default(cuid())
  email      String     @unique
  name       String?
  firstName  String?
  lastName   String?
  password   String?
  role       String     @default("COWORKER")
  auth0Id    String?    @unique
  status     String     @default("ACTIVE")
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  coworkerProfile Coworker?
  adminProfile    Admin?
  appointments    Appointment[]
  modificationRequests ModificationRequest[]
  invoices        Invoice[]
  auditLogs       AuditLog[]

  @@index([role])
  @@index([status])
}

model Coworker {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  phone              String?
  bio                String?
  specializations    String?
  profileImageUrl    String?
  iban               String?
  taxId              String?
  companyName        String?
  isActive           Boolean @default(true)
  hasRestriction     Boolean @default(false)
  restrictionReason  String?
  
  // Google Calendar Integration
  googleCalendarId       String?
  googleCalendarToken    String? // Encrypted OAuth token
  bookingLinkToken       String? @unique // Unique token for public booking link
  allowOnlineBooking     Boolean @default(false)
  bufferTimeMinutes      Int     @default(15)
  
  // Working Hours (JSON)
  workingHours       String? // JSON: {monday: [{start, end, enabled}], ...}
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  appointments       Appointment[]
  clients            CoworkerClient[]
  monthlyRecaps      MonthlyRecap[]
  bookingRestrictions BookingRestriction[]
  backlogEntries     BacklogEntry[]
  modificationRequests ModificationRequest[]
  cancellationRequests CancellationRequest[]

  @@index([isActive])
  @@index([hasRestriction])
  @@index([bookingLinkToken])
}

model Admin {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissions String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  approvedRequests ModificationRequest[]
}

model Client {
  id    String @id @default(cuid())
  email String @unique
  name  String
  phone String?
  taxId           String?
  address         String?
  city            String?
  postalCode      String?
  birthDate       DateTime?
  medicalHistory  String?
  allergies       String?
  medications     String?
  status          String @default("ACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appointments    Appointment[]
  coworkers       CoworkerClient[]
  documents       ClientDocument[]

  @@index([email])
  @@index([status])
}

model CoworkerClient {
  id          String @id @default(cuid())
  coworkerId  String
  clientId    String
  coworker    Coworker @relation(fields: [coworkerId], references: [id], onDelete: Cascade)
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([coworkerId, clientId])
  @@index([clientId])
}

model ClientDocument {
  id        String @id @default(cuid())
  clientId  String
  client    Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  fileName  String
  fileUrl   String
  fileType  String
  category  String
  uploadedAt DateTime @default(now())

  @@index([clientId])
}

model Appointment {
  id            String   @id @default(cuid())
  coworkerId    String
  clientId      String
  userId        String
  coworker      Coworker @relation(fields: [coworkerId], references: [id], onDelete: Cascade)
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id])
  startTime     DateTime
  endTime       DateTime
  durationHours Float
  type          String
  notes         String?
  status        String @default("SCHEDULED") // SCHEDULED, PENDING, COMPLETED, CANCELLED, MODIFIED
  cancelledAt   DateTime?
  cancelledBy   String?
  roomType      String
  roomNumber    Int?
  
  // Google Calendar Integration
  googleEventId      String?
  googleMeetLink     String?
  bookingSource      String @default("manual") // manual, link
  isOnline           Boolean @default(false)
  bufferEndTime      DateTime?
  reminderSent       Boolean @default(false)
  
  // Cancellation Request (JSON)
  cancellationRequest String? // JSON: {requestedAt, reason, notes, status, reviewedBy, ...}
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  modificationRequests ModificationRequest[]
  backlogEntry  BacklogEntry?
  invoices      AppointmentInvoice[]
  cancellationRequests CancellationRequest[]

  @@index([coworkerId])
  @@index([clientId])
  @@index([status])
  @@index([startTime])
  @@index([googleEventId])
}

model ModificationRequest {
  id              String @id @default(cuid())
  appointmentId   String
  coworkerId      String
  requestedBy     String
  appointment     Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  coworker        Coworker    @relation(fields: [coworkerId], references: [id], onDelete: Cascade)
  user            User        @relation(fields: [requestedBy], references: [id])
  requestType     String
  newStartTime    DateTime?
  newEndTime      DateTime?
  reason          String
  status          String @default("PENDING")
  approvedBy      String?
  approvedAdmin   Admin?      @relation(fields: [approvedBy], references: [id])
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([coworkerId])
}

model BacklogEntry {
  id            String @id @default(cuid())
  appointmentId String @unique
  coworkerId    String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  coworker      Coworker    @relation(fields: [coworkerId], references: [id], onDelete: Cascade)
  hoursWorked   Float
  roomType      String
  month         Int
  year          Int
  dayWorked     Int
  status        String @default("OPEN")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([coworkerId, year, month])
  @@index([status])
}

model MonthlyRecap {
  id          String @id @default(cuid())
  coworkerId  String
  month       Int
  year        Int
  coworker    Coworker @relation(fields: [coworkerId], references: [id], onDelete: Cascade)
  totalHours        Float
  trainingHours     Float
  treatmentHours    Float
  appointmentCount  Int
  status            String @default("OPEN")
  confirmedAt       DateTime?
  rejectionReason   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([coworkerId, year, month])
  @@index([status])
}

model Invoice {
  id              String @id @default(cuid())
  coworkerId      String
  userId          String
  month           Int
  year            Int
  coworker        User   @relation(fields: [userId], references: [id])
  totalAmount     Float
  currency        String @default("EUR")
  hoursWorked     Float
  hourlyRate      Float
  invoiceNumber   String @unique
  pdfUrl          String?
  backlogAttachmentUrl String?
  status          String @default("GENERATED")
  sentAt          DateTime?
  receivedAt      DateTime?
  paymentStatus   String @default("PENDING")
  paymentDate     DateTime?
  paymentMethod   String?
  paymentReference String?
  paymentEvidence String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([coworkerId, year, month])
  @@index([status])
  @@index([paymentStatus])
}

model AppointmentInvoice {
  id              String @id @default(cuid())
  appointmentId   String @unique
  appointment     Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  amount          Float
  currency        String @default("EUR")
  issueDate       DateTime
  dueDate         DateTime
  status          String @default("DRAFT")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([appointmentId])
  @@index([status])
  @@index([dueDate])
}

model BookingRestriction {
  id          String @id @default(cuid())
  coworkerId  String
  coworker    Coworker @relation(fields: [coworkerId], references: [id], onDelete: Cascade)
  reason      String
  description String?
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([coworkerId])
  @@index([isActive])
}

model Communication {
  id        String @id @default(cuid())
  type      String
  title     String
  message   String
  body      String
  targetRole String?
  sendToAll  Boolean @default(false)
  isPublished Boolean @default(false)
  publishedAt DateTime?
  attachmentUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reads     CommunicationRead[]

  @@index([type])
  @@index([isPublished])
}

model CommunicationRead {
  id              String @id @default(cuid())
  communicationId String
  communication   Communication @relation(fields: [communicationId], references: [id], onDelete: Cascade)
  readBy          String
  readAt          DateTime @default(now())

  @@unique([communicationId, readBy])
}

model CancellationRequest {
  id                    String   @id @default(cuid())
  appointmentId         String
  coworkerId            String
  clientId              String
  appointment           Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  coworker              Coworker    @relation(fields: [coworkerId], references: [id], onDelete: Cascade)
  
  requestedAt           DateTime
  appointmentDate       DateTime
  hoursUntilAppointment Float
  reason                String
  notes                 String?
  urgency               String @default("normal") // normal, urgent
  status                String @default("pending") // pending, approved, rejected
  reviewedBy            String?
  reviewedAt            DateTime?
  adminMessage          String?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([status])
  @@index([coworkerId])
  @@index([appointmentId])
}

model GoogleCalendarSettings {
  id                        String   @id @default(cuid())
  organizationCalendarId    String   @unique
  organizationCalendarToken String   // Encrypted OAuth token
  webhookUrl                String?
  syncEnabled               Boolean  @default(true)
  lastSyncAt                DateTime?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model AuditLog {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  changes   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entity])
}

model CapacitySnapshot {
  id        String @id @default(cuid())
  month     Int
  year      Int
  totalAvailableHours   Float @default(1500)
  totalUsedHours        Float @default(0)
  utilisationPercentage Float @default(0)
  trainingUsedHours     Float @default(0)
  treatmentUsedHours    Float @default(0)
  activeCoworkers       Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, month])
}