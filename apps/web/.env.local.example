# ============================================================================
# FRONTEND ENVIRONMENT VARIABLES - APPS/WEB
# ============================================================================
# Copy this file to .env.local and fill in the actual values

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001

# Auth0 Configuration
NEXT_PUBLIC_AUTH0_DOMAIN=your-domain.eu.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=your_client_id_here
AUTH0_CLIENT_SECRET=your_client_secret_here
AUTH0_BASE_URL=http://localhost:3000
AUTH0_AUDIENCE=https://your-api-identifier

# ============================================================================
# PRODUCTION VALUES (for Vercel)
# ============================================================================
# Set these in Vercel Dashboard → Environment Variables:
#
# NEXT_PUBLIC_API_URL=https://eqb-coworker-platform.onrender.com
# NEXT_PUBLIC_AUTH0_DOMAIN=dev-oqkdpdr4j5yoji2z.eu.auth0.com
# NEXT_PUBLIC_AUTH0_CLIENT_ID=o6TlmuKXdf0KJRdjz6LgiYWhJoKgiFNs
# AUTH0_CLIENT_SECRET=<your_secret_here>
# AUTH0_BASE_URL=https://your-vercel-domain.vercel.app
# AUTH0_AUDIENCE=https://eqb-coworker-platform.api
