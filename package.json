{
  "name": "eqb-platform",
  "version": "1.0.0",
  "description": "EQB Platform - Appointment Booking & Invoice Management System",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "biome check --fix .",
    "lint:check": "biome check .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "db:migrate": "cd apps/api && pnpm run db:migrate",
    "db:seed": "cd apps/api && pnpm run db:seed",
    "db:studio": "cd apps/api && pnpm run db:studio"
  },
  "workspaces": [
    "apps/api",
    "apps/web",
    "packages/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@types/cors": "^2.8.19",
    "@types/node": "^20.10.0",
    "turbo": "^1.13.4",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "dependencies": {
    "pg": "^8.17.2"
  }
}
